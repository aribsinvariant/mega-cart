{
  "manifest_version": 3,
  "name": "Mega Cart",
  "version": "1.0.0",
  "description": "Add items from any page to your Mega Cart carts",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}